TIMEZONE=Asia/Shanghai

APP_NAME=DooTask
APP_ENV=local
APP_RUNTIME=local
APP_KEY=
APP_DEBUG=true
APP_SCHEME=auto
APP_URL=http://127.0.0.1:2222

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=23306
DB_DATABASE=dootask
DB_USERNAME=dootask
DB_PASSWORD=123456
DB_PREFIX=pre_

SEARCH_HOST=127.0.0.1
SEARCH_PORT=9306

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=26379
REDIS_CLIENT=predis

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

LARAVELS_LISTEN_IP=127.0.0.1
LARAVELS_LISTEN_PORT=2222
LARAVELS_INOTIFY_RELOAD=false
LARAVELS_HANDLE_STATIC=true

APPSTORE_INTERNAL_URL=http://127.0.0.1:19080
APPSTORE_ENTRY_URL=http://127.0.0.1:19080/internal?language={system_lang}&theme={system_theme}
DOO_DRIVER=opensource
DOO_LIBRARY_PATH=/Users/liuxin2/Workspace/opensource/project/runtime/doo/doo.so
DOO_WORK_PATH=/Users/liuxin2/Workspace/opensource/project

# 本机直跑默认不带 AI 网关。后续如把 AI 插件单独暴露到宿主机，再按实际地址填写。
AI_INTERNAL_URL=http://127.0.0.1:19081

# 在线授权默认仍走官方；若要接本地 appstore，再覆盖此项。
ONLINE_LICENSE_APPSTORE_URL=https://appstore.dootask.com
