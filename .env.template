# Copy this file to .env. Never commit .env or put production secrets here.
# Runtime settings belong here; SMTP and other business settings are managed
# by the administrator in the web console.

# Application identity and runtime mode.
TIMEZONE=Asia/Shanghai

APP_NAME="夜莺"
APP_ENV=local
APP_RUNTIME=local
APP_KEY=
APP_DEBUG=true
APP_SCHEME=auto
APP_URL=http://127.0.0.1:2222
APP_PORT=2222

LOG_CHANNEL=stack
LOG_LEVEL=debug

# MySQL connection. Local middleware uses port 23306; production commonly
# uses port 3306 or the port exposed by the independent MySQL service.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=23306
DB_DATABASE=project
DB_USERNAME=project
DB_PASSWORD=123456
DB_PREFIX=pre_

# Manticore search endpoint. Search-dependent features require it to be
# reachable; the application can still boot while it is unavailable.
SEARCH_HOST=127.0.0.1
SEARCH_PORT=9306

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

# Redis connection. Local middleware uses port 26379; production commonly
# uses port 6379 or the port exposed by the independent Redis service.
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=26379
REDIS_CLIENT=predis

# Optional SMTP fallback. The administrator database setting `emailSetting`
# has higher priority, field by field. These values are used only when the
# corresponding database value is empty. Do not commit real credentials.
# Port 465 uses SMTPS; port 587 uses SMTP/STARTTLS.
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="夜莺"


AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# LaravelS/Swoole listener. Keep it on loopback when Nginx is the public edge.
LARAVELS_LISTEN_IP=127.0.0.1
LARAVELS_LISTEN_PORT=2222
LARAVELS_INOTIFY_RELOAD=false
LARAVELS_HANDLE_STATIC=true

# AppStore endpoints for host-run LaravelS. These require the AppStore
# middleware to be deployed separately.
APPSTORE_INTERNAL_URL=http://127.0.0.1:19080
APPSTORE_ENTRY_URL=http://127.0.0.1:19080/internal?language={system_lang}&theme={system_theme}
DOO_DRIVER=opensource
# 本机直跑默认不带 AI 网关。后续如把 AI 插件单独暴露到宿主机，再按实际地址填写。
AI_INTERNAL_URL=http://127.0.0.1:19081

# 在线授权默认仍走中央服务；如社区部署自己的授权服务，再覆盖此项。
ONLINE_LICENSE_APPSTORE_URL=https://appstore.dootask.com
