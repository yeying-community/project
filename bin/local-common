#!/bin/bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

require_cmd() {
    local cmd="$1"
    if ! command -v "${cmd}" >/dev/null 2>&1; then
        echo "missing command: ${cmd}" >&2
        exit 1
    fi
}

require_php_runtime() {
    require_cmd php
    require_cmd composer
}

env_config_value() {
    local key="$1"
    local env_file="${ROOT_DIR}/.env"
    local line

    line="$(grep -E "^${key}=" "${env_file}" | tail -n 1 || true)"
    printf '%s' "${line#*=}" | tr -d '\r'
}

prepare_local_env() {
    if [ ! -f "${ROOT_DIR}/.env" ]; then
        cp "${ROOT_DIR}/.env.template" "${ROOT_DIR}/.env"
        echo "Created .env from .env.template. Review the DB/Redis settings before starting." >&2
    fi
}

require_local_env_config() {
    local env_file="${ROOT_DIR}/.env"
    local missing=()
    local empty=()
    local required_keys=(
        APP_RUNTIME
        APP_URL
        DB_CONNECTION
        DB_HOST
        DB_PORT
        DB_DATABASE
        DB_USERNAME
        DB_PASSWORD
        REDIS_HOST
        REDIS_PORT
        REDIS_CLIENT
        LARAVELS_LISTEN_IP
        LARAVELS_LISTEN_PORT
        RUNTIME_DRIVER
    )
    local non_empty_keys=(
        APP_RUNTIME
        APP_URL
        DB_CONNECTION
        DB_HOST
        DB_PORT
        DB_DATABASE
        DB_USERNAME
        REDIS_HOST
        REDIS_PORT
        REDIS_CLIENT
        LARAVELS_LISTEN_IP
        LARAVELS_LISTEN_PORT
        RUNTIME_DRIVER
    )
    local key

    for key in "${required_keys[@]}"; do
        if ! grep -q "^${key}=" "${env_file}"; then
            missing+=("${key}")
        fi
    done

    for key in "${non_empty_keys[@]}"; do
        if grep -q "^${key}=" "${env_file}" && [ -z "$(env_config_value "${key}")" ]; then
            empty+=("${key}")
        fi
    done

    if [ "${#missing[@]}" -gt 0 ] || [ "${#empty[@]}" -gt 0 ]; then
        if [ "${#missing[@]}" -gt 0 ]; then
            echo ".env is missing required settings: ${missing[*]}" >&2
        fi
        if [ "${#empty[@]}" -gt 0 ]; then
            echo ".env has empty required settings: ${empty[*]}" >&2
        fi
        echo "Fill these values in .env, then rerun the command." >&2
        exit 1
    fi

    if [ "$(env_config_value APP_RUNTIME)" != "local" ]; then
        echo "./cmd local-* commands require APP_RUNTIME=local in .env." >&2
        exit 1
    fi
}

require_local_database_ready() {
    local status_output=""

    cd "${ROOT_DIR}"
    if ! status_output="$(php artisan migrate:status --no-interaction 2>&1)"; then
        echo "Local database is not ready. Run ./cmd local-install after checking .env DB settings." >&2
        printf '%s\n' "$status_output" >&2
        exit 1
    fi

    if printf '%s\n' "$status_output" | grep -qE 'Migration table not found|Pending'; then
        echo "Local database has not been initialized or has pending migrations." >&2
        echo "Run ./cmd local-install before ./cmd local-start." >&2
        exit 1
    fi
}

prepare_runtime_dirs() {
    mkdir -p \
        "${ROOT_DIR}/bootstrap/cache" \
        "${ROOT_DIR}/storage/app" \
        "${ROOT_DIR}/storage/framework/cache" \
        "${ROOT_DIR}/storage/framework/cache/data" \
        "${ROOT_DIR}/storage/framework/sessions" \
        "${ROOT_DIR}/storage/framework/testing" \
        "${ROOT_DIR}/storage/framework/views" \
        "${ROOT_DIR}/storage/logs"
}
